---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import CreditKarmaAd from '../components/CreditKarmaAd.astro';
import FAQ from '../components/FAQ.astro';
import { SITE, PRODUCTS } from '../consts';

// Surface the latest guides directly from the homepage (the highest-authority
// page) so interior article URLs get a strong internal link and get crawled, 
// the fix for "Discovered - currently not indexed".
const includeDrafts = import.meta.env.DEV;
const latestPosts = (
  await getCollection('articles', ({ data }) => (includeDrafts ? true : data.published))
)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const faqs = [
  {
    q: 'Can I get a credit card with an ITIN instead of an SSN?',
    a: 'Yes. Many U.S. banks, credit unions, and fintech companies accept an Individual Taxpayer Identification Number in place of a Social Security Number. A secured credit card, backed by a refundable deposit, is the easiest entry point for ITIN holders with no prior U.S. credit history.',
  },
  {
    q: 'Will getting a credit card with my ITIN build a credit score?',
    a: 'Yes, provided the issuer reports to the three major credit bureaus, Equifax, Experian, and TransUnion. Paying on time each month is the single most powerful credit-building action (payment history = 35% of FICO). Most major secured card programs report to all three bureaus.',
  },
  {
    q: 'How much does a secured card deposit cost?',
    a: 'Most secured cards require a minimum deposit of $200 to $500. The deposit is fully refundable, you get it back when you close the account or are upgraded to an unsecured card. It is not applied to your monthly payments; it simply secures the credit line.',
  },
  {
    q: 'How long does it take to go from zero to a good credit score?',
    a: 'A FICO score appears after six months of activity on a reporting account. A score in the "fair" range (580-669) typically takes 12 months. Reaching "good" (670+) takes 18-24 months of consistent on-time payments and low utilization. The timeline is predictable and the inputs are within your control.',
  },
  {
    q: 'Is ITINCreditCard.com a bank or card issuer?',
    a: 'No. We are an independent information and card-matching resource. We publish guides and help ITIN holders find card issuers that accept their ITIN. We do not issue cards, make credit decisions, or set card terms. All cards are provided by third-party issuers.',
  },
];
---
<BaseLayout title={SITE.name} ogImage="/og/home.png">
  <!-- Spotlight hero (image-led, bold) -->
  <section class="spotlight">
    <img class="spotlight-photo" src="/img/credit-cards.webp" alt="A stack of credit cards on a clean surface" loading="eager" fetchpriority="high" decoding="async" />
    <div class="container spotlight-stage">
      <div class="spotlight-copy">
        <span class="spotlight-chip">No SSN required</span>
        <h1>Get a credit card with your ITIN, no SSN required</h1>
        <p class="lede">
          Building U.S. credit with an ITIN is possible, and faster than most people expect.
          We help ITIN holders find the right card, understand how approval works, and grow
          their score step by step.
        </p>
        <div class="spotlight-cta">
          <a href="/apply" class="btn btn-gold btn-lg">Find your card</a>
          <a href="/itin-credit-cards-guide" class="btn btn-secondary btn-lg">How ITIN credit cards work</a>
        </div>
        <div class="spotlight-proof">
          <span class="proof-pill"><span class="check">&#10003;</span> No SSN needed</span>
          <span class="proof-pill"><span class="check">&#10003;</span> No credit impact to check</span>
          <span class="proof-pill"><span class="check">&#10003;</span> Secured &amp; unsecured options</span>
        </div>
      </div>
      <div class="spotlight-aside">
        <CreditKarmaAd creativeId="3641203" cta="Shop our partner credit cards here" alt="Credit Karma, everything you need to grow your finances" />
      </div>
    </div>
  </section>

  <!-- Products deck -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-kicker">Pick your path</span>
        <h2>What do you need today?</h2>
        <p>Whether you're starting from zero or ready to upgrade, pick a path and we'll walk you through it.</p>
      </div>
      <div class="card-grid">
        {PRODUCTS.map((p) => (
          <a class="card" href={`/${p.slug}`}>
            <div class="card-icon"><Icon name={p.icon} size={28} /></div>
            <h3>{p.label}</h3>
            <p>{p.blurb}</p>
            <span class="arrow">Learn more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section section-surface">
    <div class="container">
      <div class="section-head">
        <span class="section-kicker">Three quick steps</span>
        <h2>How it works</h2>
        <p>Three steps from "Can I even get a card?" to a real card in your wallet.</p>
      </div>
      <div class="steps">
        <div class="step">
          <div class="num">1</div>
          <h3>Tell us what you need</h3>
          <p>Answer a few quick questions about the type of card you're after and your state. Takes under a minute, no SSN, no credit pull.</p>
        </div>
        <div class="step">
          <div class="num">2</div>
          <h3>Get matched</h3>
          <p>We connect you with ITIN-friendly card issuers that fit your situation, so you're not cold-calling banks that will say no. See <a href="/credit-cards-that-accept-itin">which credit cards accept an ITIN</a> and compare the <a href="/best-itin-credit-cards">best ITIN credit cards</a> to pick the right one for you.</p>
        </div>
        <div class="step">
          <div class="num">3</div>
          <h3>Apply &amp; start building</h3>
          <p>Apply with the issuer directly, get your card, and start building the credit history that opens doors to better products.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats / trust band -->
  <section class="section-tight">
    <div class="container">
      <div class="stats">
        <div class="stat"><div class="big">5.8M+</div><div class="lbl">ITINs issued by the IRS</div></div>
        <div class="stat"><div class="big">35%</div><div class="lbl">Payment history = FICO score</div></div>
        <div class="stat"><div class="big">3</div><div class="lbl">Major bureaus that track your score</div></div>
        <div class="stat"><div class="big">$0</div><div class="lbl">Cost to check your options</div></div>
      </div>
    </div>
  </section>

  <!-- Latest guides -->
  {latestPosts.length > 0 && (
    <section class="section section-surface">
      <div class="container narrow">
        <div class="section-head">
          <span class="section-kicker">Fresh off the desk</span>
          <h2>Latest ITIN credit card guides</h2>
          <p>Plain-English walkthroughs for getting and using a credit card with an ITIN.</p>
        </div>
        <div class="post-list">
          {latestPosts.map((post) => (
            <a class="post-card" href={`/articles/${post.slug}`}>
              <div>
                <span class="meta">{post.data.category}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </div>
              <span class="tag">{post.data.tier}</span>
            </a>
          ))}
        </div>
        <p style="margin-top:18px"><a href="/articles">View all ITIN credit card guides &rarr;</a></p>
      </div>
    </section>
  )}

  <!-- Starter guides + Spanish hub: high-authority homepage links into the
       most common starting-point questions (and the /es home) so these pages
       get crawled and indexed faster on a young domain. -->
  <section class="section">
    <div class="container narrow">
      <div class="section-head">
        <span class="section-kicker">Start here</span>
        <h2>Just getting started with an ITIN credit card?</h2>
        <p>These plain-English walkthroughs answer the questions most first-time applicants ask.</p>
      </div>
      <ul class="lead-list">
        <li><a href="/articles/can-you-get-a-credit-card-with-an-itin">Can you get a credit card with an ITIN?</a> &mdash; the short answer, and exactly how it works.</li>
        <li><a href="/articles/how-to-apply-for-credit-card-with-itin">How to apply for a credit card with an ITIN</a>, step by step.</li>
        <li><a href="/articles/first-credit-card-itin-no-us-credit-history">Getting your first card with no U.S. credit history</a>.</li>
        <li><a href="/articles/which-banks-accept-itin-for-credit-cards">Which banks accept an ITIN for credit cards</a>.</li>
        <li><a href="/articles/no-credit-check-credit-card-itin">No-credit-check card options for ITIN holders</a>.</li>
        <li><a href="/articles/credit-card-prequalification-itin">How to pre-qualify for a card with an ITIN</a> before you apply.</li>
      </ul>
      <p style="margin-top:18px">¿Prefieres español? <a href="/es">Visita nuestra guía de tarjetas de crédito con ITIN en español &rarr;</a></p>
    </div>
  </section>

  <!-- CTA band -->
  <section class="section">
    <div class="container">
      <div class="cta-band">
        <h2>Your ITIN is enough to start.</h2>
        <p>Thousands of ITIN holders get approved for credit cards every year. Find out which card fits your situation, it's free and it won't touch your credit score.</p>
        <a href="/apply" class="btn btn-gold btn-lg">Find your card</a>
      </div>
    </div>
  </section>

  <!-- Homepage FAQ -->
  <section class="section section-surface">
    <div class="container narrow">
      <FAQ faqs={faqs} heading="ITIN credit cards: common questions" />
    </div>
  </section>
</BaseLayout>
