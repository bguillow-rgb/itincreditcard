---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import CreditKarmaAd from '../../components/CreditKarmaAd.astro';
import FAQ from '../../components/FAQ.astro';
import LeadForm from '../../components/LeadForm.astro';
import FhaPromo from '../../components/FhaPromo.astro';
import { SITE, PRODUCTS } from '../../consts';

const faqs = [
  {
    q: '¿Puedo obtener una tarjeta de crédito con un ITIN en lugar de un Seguro Social?',
    a: 'Sí. Muchos bancos, cooperativas de crédito y empresas fintech de EE. UU. aceptan un Número de Identificación Personal del Contribuyente en lugar de un Seguro Social. Una tarjeta con garantía, respaldada por un depósito reembolsable, es la entrada más fácil para personas con ITIN sin historial crediticio previo en EE. UU.',
  },
  {
    q: '¿Obtener una tarjeta de crédito con mi ITIN construirá un puntaje de crédito?',
    a: 'Sí, siempre que el emisor reporte a los tres burós de crédito principales, Equifax, Experian y TransUnion. Pagar a tiempo cada mes es la acción más poderosa para construir crédito (el historial de pagos = 35% del FICO). La mayoría de los programas importantes de tarjetas con garantía reportan a los tres burós.',
  },
  {
    q: '¿Cuánto cuesta el depósito de una tarjeta con garantía?',
    a: 'La mayoría de las tarjetas con garantía requieren un depósito mínimo de $200 a $500. El depósito es totalmente reembolsable, lo recuperas cuando cierras la cuenta o te actualizan a una tarjeta sin garantía. No se aplica a tus pagos mensuales; simplemente respalda la línea de crédito.',
  },
  {
    q: '¿Cuánto tarda en pasar de cero a un buen puntaje de crédito?',
    a: 'Un puntaje FICO aparece después de seis meses de actividad en una cuenta que reporta. Un puntaje en el rango "regular" (580-669) suele tomar 12 meses. Llegar a "bueno" (670+) toma de 18 a 24 meses de pagos puntuales constantes y baja utilización. El plazo es predecible y los factores están bajo tu control.',
  },
  {
    q: '¿Es ITINCreditCard.com un banco o emisor de tarjetas?',
    a: 'No. Somos un recurso independiente de información y de conexión con tarjetas. Publicamos guías y ayudamos a personas con ITIN a encontrar emisores de tarjetas que acepten su ITIN. No emitimos tarjetas, no tomamos decisiones de crédito ni fijamos términos de tarjetas. Todas las tarjetas las proporcionan emisores externos.',
  },
];
---
<BaseLayout title={SITE.name} ogImage="/og/home.png">
  <!-- Spotlight hero (image-led, bold) -->
  <section class="spotlight">
    <img class="spotlight-photo" src="/img/credit-cards.webp" alt="Varias tarjetas de crédito sobre una superficie limpia" loading="eager" fetchpriority="high" decoding="async" />
    <div class="container spotlight-stage">
      <div class="spotlight-copy">
        <span class="spotlight-chip">Sin Seguro Social</span>
        <h1>Obtén una tarjeta de crédito con tu ITIN, sin Seguro Social</h1>
        <p class="lede">
          Construir crédito en EE. UU. con un ITIN es posible, y más rápido de lo que
          la mayoría espera. Ayudamos a personas con ITIN a encontrar la tarjeta
          correcta, entender cómo funciona la aprobación y aumentar su puntaje paso a
          paso.
        </p>
        <div class="spotlight-cta">
          <a href="#lead" class="btn btn-gold btn-lg">Encuentra tu tarjeta</a>
          <a href="/es/itin-credit-cards-guide" class="btn btn-secondary btn-lg">Cómo funcionan las tarjetas con ITIN</a>
        </div>
        <div class="spotlight-proof">
          <span class="proof-pill"><span class="check">&#10003;</span> Sin Seguro Social</span>
          <span class="proof-pill"><span class="check">&#10003;</span> Revisar no afecta tu crédito</span>
          <span class="proof-pill"><span class="check">&#10003;</span> Opciones con y sin garantía</span>
        </div>
      </div>
      <div class="spotlight-aside ihero-form" id="lead">
        <LeadForm compact heading="Encuentra tu tarjeta ITIN — gratis" />
      </div>
    </div>
  </section>

  <!-- Promo de socio FHA-para-ITIN. El CTA principal salta al formulario del hero (#lead). -->
  <FhaPromo href="#lead" />

  <!-- Anuncio de socio reubicado bajo el pliegue para que la portada empiece con el formulario. -->
  <section class="section-tight">
    <div class="container narrow" style="text-align:center">
      <CreditKarmaAd creativeId="3641203" cta="Compra nuestras tarjetas asociadas aquí" alt="Credit Karma, todo para hacer crecer tus finanzas" inline={true} />
    </div>
  </section>

  <!-- Products deck -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-kicker">Elige tu camino</span>
        <h2>¿Qué necesitas hoy?</h2>
        <p>Ya sea que empieces desde cero o estés listo para mejorar, elige un camino y te guiamos paso a paso.</p>
      </div>
      <div class="card-grid">
        {PRODUCTS.map((p) => (
          <a class="card" href={`/es/${p.slug}`}>
            <div class="card-icon"><Icon name={p.icon} size={28} /></div>
            <h3>{p.labelEs}</h3>
            <p>{p.blurbEs}</p>
            <span class="arrow">Más información &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section section-surface">
    <div class="container">
      <div class="section-head">
        <span class="section-kicker">Tres pasos rápidos</span>
        <h2>Cómo funciona</h2>
        <p>Tres pasos para pasar de "¿puedo siquiera obtener una tarjeta?" a una tarjeta real en tu cartera.</p>
      </div>
      <div class="steps">
        <div class="step">
          <div class="num">1</div>
          <h3>Cuéntanos qué necesitas</h3>
          <p>Responde unas preguntas rápidas sobre el tipo de tarjeta que buscas y tu estado. Toma menos de un minuto, sin Seguro Social, sin consulta de crédito.</p>
        </div>
        <div class="step">
          <div class="num">2</div>
          <h3>Conéctate</h3>
          <p>Te conectamos con emisores de tarjetas que aceptan ITIN y se ajustan a tu situación, para que no tengas que llamar en frío a bancos que te dirán que no.</p>
        </div>
        <div class="step">
          <div class="num">3</div>
          <h3>Solicita y empieza a construir</h3>
          <p>Solicita directamente con el emisor, obtén tu tarjeta y empieza a construir el historial crediticio que abre las puertas a mejores productos.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats / trust band -->
  <section class="section-tight">
    <div class="container">
      <div class="stats">
        <div class="stat"><div class="big">5.8M+</div><div class="lbl">ITIN emitidos por el IRS</div></div>
        <div class="stat"><div class="big">35%</div><div class="lbl">Historial de pagos = puntaje FICO</div></div>
        <div class="stat"><div class="big">3</div><div class="lbl">Burós principales que rastrean tu puntaje</div></div>
        <div class="stat"><div class="big">$0</div><div class="lbl">Costo de revisar tus opciones</div></div>
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <section class="section">
    <div class="container">
      <div class="cta-band">
        <h2>Tu ITIN es suficiente para empezar.</h2>
        <p>Miles de personas con ITIN son aprobadas para tarjetas de crédito cada año. Descubre qué tarjeta se ajusta a tu situación, es gratis y no afecta tu puntaje de crédito.</p>
        <a href="/es/apply" class="btn btn-gold btn-lg">Encuentra tu tarjeta</a>
      </div>
    </div>
  </section>

  <!-- Homepage FAQ -->
  <section class="section section-surface">
    <div class="container narrow">
      <FAQ faqs={faqs} heading="Tarjetas de crédito con ITIN: preguntas frecuentes" />
    </div>
  </section>
</BaseLayout>
