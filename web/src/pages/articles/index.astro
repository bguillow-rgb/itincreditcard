---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CollectionPageSchema from '../../components/schema/CollectionPageSchema.astro';
import { SITE } from '../../consts';

const includeDrafts = import.meta.env.DEV;
const posts = (
  await getCollection('articles', ({ data }) =>
    includeDrafts ? true : data.published
  )
).sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const title = 'ITIN Credit Card Guides';
const description =
  'Plain-English guides to getting a credit card with an ITIN, building U.S. credit, secured vs unsecured cards, and how FICO scoring works for ITIN holders.';

const itemList = posts.map((p) => ({
  name: p.data.title,
  url: `${SITE.url}/articles/${p.slug}`,
}));
---
<BaseLayout title={title} description={description} path="/articles">
  <Fragment slot="head">
    <CollectionPageSchema
      name={title}
      description={description}
      url={`${SITE.url}/articles`}
      items={itemList}
    />
  </Fragment>
  <section class="section">
    <div class="container narrow">
      <span class="tag">Guides</span>
      <h1 style="margin-top:10px">ITIN credit card guides</h1>
      <p class="lede" style="color:var(--muted)">
        Everything we know about getting a credit card and building credit with an ITIN —
        written for real people, not bankers.
      </p>

      {posts.length === 0 ? (
        <p>New guides are publishing soon. In the meantime,
          <a href="/itin-credit-cards-guide">start with our complete ITIN credit card guide</a>.</p>
      ) : (
        <div class="post-list">
          {posts.map((post) => (
            <a class="post-card" href={`/articles/${post.slug}`}>
              <div>
                <span class="meta">{post.data.category}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </div>
              <span class="tag">{post.data.tier}</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
